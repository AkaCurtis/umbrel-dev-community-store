server=1
txindex=0

# Pruning: disabled by default (archival).
prune=0

# Allocate more RAM for database cache during sync (in MB)
dbcache=4000

# Skip mempool transactions during IBD (faster sync)
blocksonly=1

# Allow more peers (helps initial sync + network robustness).
maxconnections=256

# Add reliable nodes for faster peer discovery
addnode=seed.bitcoin.sipa.be
addnode=dnsseed.bluematt.me
addnode=dnsseed.bitcoin.dashjr.org
addnode=seed.bitcoinstats.com
addnode=seed.bitcoin.jonasschnelli.ch
addnode=seed.btc.petertodd.org

# Mainnet only.

# Ports
port=${BTC_P2P_PORT}
rpcport=${BTC_RPC_PORT}

# RPC (not published to the host by default; internal apps only)
rpcworkqueue=128
rpcthreads=16
rpcuser=${RPC_USER}
rpcpassword=${RPC_PASSWORD}
rpcbind=0.0.0.0
rpcallowip=127.0.0.1/32
rpcallowip=${APPS_SUBNET}
rpcallowip=10.0.0.0/8
rpcallowip=172.16.0.0/12
rpcallowip=192.168.0.0/16

# ZMQ (for pool notifications)
zmqpubhashblock=tcp://0.0.0.0:${BTC_ZMQ_HASHBLOCK_PORT}
